pipeline {
    agent any
    parameters {
       choice choices: ['Apache', 'Nginx'], name: 'WEBSERVER'
    }
       
      environment {
          WEBSERVER = 'Nginx'
          JENKINS_WEB_ROOT = '/usr/share/nginx/html'
          HOST_WEB_ROOT = '/home/mcherlo/docker/jenkins/app-web'
          CONTAINER_NAME = 'app-web'
      }

      stages {
          stage('Prepare directory for the web application') {
              steps {
                  sh 'mkdir -p ${JENKINS_WEB_ROOT}'
                  sh 'find ${JENKINS_WEB_ROOT} -mindepth 1 -maxdepth 1 -exec rm -rf {} +'
              }
          }

          stage('Drop the container') {
              steps {
                  echo 'droping the container...'
                  sh 'docker rm -f ${CONTAINER_NAME} || true'
              }
          }

          stage('Copy the web application') {
              steps {
                  echo 'Copying web application...'
                  sh 'test -d web'
                  sh 'cp -a web/. ${JENKINS_WEB_ROOT}/'
                  sh 'ls -la ${JENKINS_WEB_ROOT}'
              }
          }

          stage('Create the Apache container') {
              when {
                  environment name: 'WEBSERVER', value: 'Apache'
              }
              steps {
                  sh 'docker run -dit --name ${CONTAINER_NAME} -p 9100:80 -v ${HOST_WEB_ROOT}:/usr/local/apache2/htdocs/ httpd'
              }
          }

          stage('Create the Nginx container') {
              when {
                  environment name: 'WEBSERVER', value: 'Nginx'
              }
              steps {
                  sh 'docker run -dit --name ${CONTAINER_NAME} -p 9100:80 -v ${HOST_WEB_ROOT}:/usr/share/nginx/html nginx'
              }
          }
      }

      post {
          always {
              echo 'These steps are always executed'
          }
          success {
              echo 'the deployment has worked'
              archiveArtifacts allowEmptyArchive: true, artifacts: 'web/*', followSymlinks: false
              cleanWs()
          }
          failure {
              echo 'An error has ocurred'
          }
      }
  }
