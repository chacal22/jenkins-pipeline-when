  pipeline {
      agent any

      parameters {
          choice(name: 'WEBSERVER', choices: ['Apache', 'Nginx'], description: 'Web server to deploy')
          choice(name: 'ENV', choices: ['Development', 'Test', 'Production'], description: 'Target environment')
      }

      environment {
          JENKINS_WEB_ROOT = '/opt/app-web'
          HOST_WEB_ROOT = '/home/mcherlo/docker/jenkins/app-web'
          CONTAINER_NAME = 'app-web'
      }

      stages {
          stage('Validate deployment combination') {
              steps {
                  script {
                      if (params.WEBSERVER == 'Nginx' && params.ENV == 'Development') {
                          error('Nginx cannot be deployed in Development')
                      }

                      if (params.WEBSERVER == 'Apache' && (params.ENV == 'Test' || params.ENV == 'Production')) {
                          error('Apache cannot be deployed in Test or Production environments')
                      }
                  }
              }
          }

          stage('Create directory for the WEB Application') {
              when {
                  equals(actual: currentBuild.number, expected: 1)
              }
              steps {
                  echo 'Creating application directory for the first build...'
                  sh 'mkdir -p ${JENKINS_WEB_ROOT}'
              }
          }

          stage('Clean web application directory') {
              steps {
                  echo "Web server: ${params.WEBSERVER}"
                  echo "Environment: ${params.ENV}"
                  sh 'mkdir -p ${JENKINS_WEB_ROOT}'
                  sh 'find ${JENKINS_WEB_ROOT} -mindepth 1 -maxdepth 1 -exec rm -rf {} +'
              }
          }

          stage('Drop the container') {
              steps {
                  echo 'dropping the container...'
                  sh 'docker rm -f ${CONTAINER_NAME} || true'
              }
          }

          stage('Copy the web application to the container directory') {
              steps {
                  echo 'Copying web application...'
                  sh 'test -d web'
                  sh 'cp -a web/. ${JENKINS_WEB_ROOT}/'
                  sh 'ls -la ${JENKINS_WEB_ROOT}'
              }
          }

          stage('Create the Apache container in Development') {
              when {
                  expression { params.WEBSERVER == 'Apache' && params.ENV == 'Development' }
              }
              steps {
                  echo 'Creating the Apache container...'
                  sh 'docker run -dit --name ${CONTAINER_NAME} -p 9100:80 -v ${HOST_WEB_ROOT}:/usr/local/apache2/htdocs/ httpd'
              }
          }

          stage('Create the Nginx container in Test') {
              when {
                  expression { params.WEBSERVER == 'Nginx' && params.ENV == 'Test' }
              }
              steps {
                  echo 'Creating the Nginx container for Test...'
                  sh 'docker run -dit --name ${CONTAINER_NAME} -p 9100:80 -v ${HOST_WEB_ROOT}:/usr/share/nginx/html nginx'
              }
          }

          stage('Create the Nginx container in Production') {
              when {
                  expression { params.WEBSERVER == 'Nginx' && params.ENV == 'Production' }
              }
              steps {
                  echo 'Creating the Nginx container for Production...'
                  sh 'docker run -dit --name ${CONTAINER_NAME} -p 9100:80 -v ${HOST_WEB_ROOT}:/usr/share/nginx/html nginx'
              }
          }
      }

      post {
          always {
              echo 'These steps are always executed'
          }

          success {
              echo 'the deployment has worked'
              archiveArtifacts allowEmptyArchive: true, artifacts: 'web/*', followSymlinks: false
              cleanWs()
          }

          failure {
              echo 'An error has ocurred'
          }
      }
  }
